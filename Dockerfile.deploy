FROM gcr.io/distroless/static-debian13@sha256:47b2d72ff90843eb8a768b5c2f89b40741843b639d065b9b937b07cd59b479c6
WORKDIR /app

ARG TARGETARCH

COPY backend-bin/linux_${TARGETARCH}/app /app/app
COPY ui-build/build /app/internal/ui/build

VOLUME ["/data"]
EXPOSE 8080
USER 1000:1000
ENTRYPOINT ["/app/app"]