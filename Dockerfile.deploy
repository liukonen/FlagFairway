FROM gcr.io/distroless/static-debian13@sha256:3592aa8171c77482f62bbc4164e6a2d141c6122554ace66e5cc910cadb961ff0
WORKDIR /app

ARG TARGETARCH

COPY backend-bin/linux_${TARGETARCH}/app /app/app
COPY ui-build/build /app/internal/ui/build

VOLUME ["/data"]
EXPOSE 8080
USER 1000:1000
ENTRYPOINT ["/app/app"]